{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "types": ["node"],
    "outDir": "./dist",
    "rootDir": "./",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": false,
    "jsx": "react",
    "allowSyntheticDefaultImports": true
  },
  "include": ["bin/**/*", "lib/**/*", "src/**/*"],
  "exclude": ["node_modules", "dist", "themes", "assets", "docs", "scripts", "tests"]
}