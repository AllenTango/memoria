{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": [
      "ES2020"
    ],
    "types": [
      "node"
    ],
    "outDir": "./dist",
    "rootDir": "./",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": false,
    "allowSyntheticDefaultImports": true,
    "moduleResolution": "bundler"
  },
  "include": [
    "bin/**/*",
    "lib/**/*",
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "themes",
    "assets",
    "docs",
    "scripts",
    "tests",
    "src/tui/**/*"
  ]
}