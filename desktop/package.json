{
  "name": "memoria-desktop",
  "version": "1.0.0",
  "description": "Memoria Desktop - 轻量级静态博客桌面写作软件",
  "main": "./dist/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "vue": "^3.5.0",
    "vue-router": "^4.4.0",
    "pinia": "^2.2.0",
    "marked": "^12.0.0",
    "gray-matter": "^4.0.3",
    "highlight.js": "^11.9.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.1.0",
    "electron": "^33.0.0",
    "electron-vite": "^2.3.0",
    "electron-builder": "^25.0.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vue-tsc": "^2.1.0",
    "@types/node": "^22.0.0"
  },
  "build": {
    "appId": "com.memoria.desktop",
    "productName": "Memoria",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "resources/**/*"
    ],
    "mac": {
      "target": ["dmg", "zip"],
      "icon": "resources/icon.png"
    },
    "win": {
      "target": ["nsis", "zip"],
      "icon": "resources/icon.ico"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "resources/icon.png"
    }
  }
}
