{
  "name": "memoria",
  "version": "1.0.0",
  "type": "module",
  "description": "轻型静态博客系统，支持文章/视讯/相册三种内容形态",
  "bin": {
    "memoria": "dist/cli.js"
  },
  "scripts": {
    "bundle": "esbuild bin/memoria.ts --bundle --platform=node --format=esm --target=node18 --outfile=dist/cli.js --banner:js=\"#!/usr/bin/env node\" --jsx=automatic --jsx-import-source=react --external:react --external:ink --external:react-devtools-core --external:gray-matter --external:highlight.js --external:marked --external:prompts",
    "build": "npm run bundle && chmod +x dist/cli.js"
  },
  "keywords": [
    "static-site-generator",
    "blog",
    "memoria"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "highlight.js": "^11.9.0",
    "ink": "^7.0.5",
    "marked": "^12.0.0",
    "prompts": "^2.4.2",
    "react": "^19.2.6",
    "react-devtools-core": "^7.0.1"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}